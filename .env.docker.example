# Copy this file to .env before running docker compose.
#
# Local example:
# NEXT_PUBLIC_HEOGAON_API_BASE_URL=http://127.0.0.1:4100
# CORS_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
#
# Hackathon server example:
# NEXT_PUBLIC_HEOGAON_API_BASE_URL=http://h14k010.p.ssafy.io:4100
# CORS_ALLOWED_ORIGINS=http://h14k010.p.ssafy.io

NEXT_PUBLIC_HEOGAON_API_BASE_URL=http://h14k010.p.ssafy.io:4100
CORS_ALLOWED_ORIGINS=http://h14k010.p.ssafy.io

ENABLE_LLM=true
ENABLE_DEMO_FALLBACK=true
ENABLE_GRAPH_RAG=false

LLM_PROVIDER=gms
LLM_API_KEY=
LLM_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
LLM_MODEL=gpt-5.5
LLM_REASONING_EFFORT=low
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT_SECONDS=12

GRAPH_RAG_BASE_URL=
GRAPH_RAG_API_KEY=
GRAPH_RAG_TIMEOUT_SECONDS=8
