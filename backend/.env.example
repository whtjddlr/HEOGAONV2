APP_ENV=local
ENABLE_LLM=true
ENABLE_DEMO_FALLBACK=true
ENABLE_GRAPH_RAG=false

# OpenAI-compatible LLM. OPENAI_API_KEY is also accepted as fallback.
LLM_PROVIDER=openai-compatible
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=12

# GraphRAG domain expansion. When disabled or unavailable, catalog fallback is used.
GRAPH_RAG_BASE_URL=
GRAPH_RAG_API_KEY=
GRAPH_RAG_TIMEOUT_SECONDS=8
