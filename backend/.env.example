APP_ENV=local
ENABLE_LLM=true
ENABLE_DEMO_FALLBACK=true
ENABLE_GRAPH_RAG=false

# GMS LLM API. GMS_API_KEY is also accepted as a fallback.
LLM_PROVIDER=gms
LLM_API_KEY=
LLM_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
LLM_MODEL=gpt-5.5
LLM_REASONING_EFFORT=low
LLM_MAX_OUTPUT_TOKENS=1024
LLM_TIMEOUT_SECONDS=12

# GraphRAG domain expansion. When disabled or unavailable, catalog fallback is used.
GRAPH_RAG_BASE_URL=
GRAPH_RAG_API_KEY=
GRAPH_RAG_TIMEOUT_SECONDS=8
