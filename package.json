{
  "name": "heogaon-flow-v2",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && .venv/bin/uvicorn app.main:app --reload --host 0.0.0.0 --port 4100",
    "dev:frontend": "cd frontend && npm run dev -- --port 3100",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && python3 -m venv .venv && . .venv/bin/activate && pip install -r requirements.txt",
    "build": "cd frontend && npm run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
